{
  "name": "yor-talks-backend",
  "version": "2.0.0",
  "description": "Yor Talks Production API",
  "main": "server.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning server.js",
