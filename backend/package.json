    "seed":  "node --disable-warning=ExperimentalWarning utils/seed.js"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "compression":       "^1.7.4",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.1",
    "express":           "^4.18.2",
    "express-rate-limit":"^7.2.0",
    "express-validator": "^7.0.1",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "multer":            "^1.4.5-lts.1",
    "nodemailer":        "^6.9.10",
    "otplib":            "^12.0.1",
    "sharp":             "^0.33.2",
    "socket.io":         "^4.6.2",
    "uuid":              "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
