# ── Yor Talks Backend Environment ─────────────────────────────────────────────
# Copy to .env and update values

PORT=5000
NODE_ENV=development

# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=yor-talks-change-this-secret-min-32-chars-xyz

# JWT token lifetimes
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=30d

# SQLite database path
DB_PATH=./data/yortalks.db

# Upload storage path
UPLOAD_DIR=./uploads

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Email (optional - logs to console if not set)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Yor Talks <noreply@yortalks.com>
